int main()
{	
    void serbo(int port, int target, int SERVO_DELAY)
{
    int pos = get_servo_position(port);

    if(pos < target)
    {
        while(pos < target)
        {
            pos += SERVO_STEP;
            set_servo_position(port, pos);
            msleep(SERVO_DELAY);
        }
    }
    else
    {
        while(pos > target)
        {
            pos -= SERVO_STEP;
            set_servo_position(port, pos);
            msleep(SERVO_DELAY);
        }
    }

    set_servo_position(port, target);
    msleep(200);
}


void openClaw(int speed){
	cmpc(lclaw);
    cmpc(rclaw);
    while(gmpc(lclaw) > lclaw_open_val && gmpc(rclaw) > rclaw_open_val  ){
        mav(lclaw, -(speed));
        mav(rclaw, -(speed));
        msleep(1);
    }
    freeze(lclaw);
    freeze(rclaw);
	}
	


void openRear(int speed){
    serbo(rear, rear_open, speed);

}
void armUp(int speed){
    serbo(arm, arm_up_val, speed);
}

void claw_squareUp(){
    mav(lclaw, 500);
    mav(rclaw, 500);
    msleep(1500);
    ao();
    cmpc(lclaw);
    cmpc(rclaw);
}



	enable_servos();
	
    
	armUp(slow);
    claw_squareUp();
	openClaw(claw_std);
	openRear(std);
    return 0;
}
