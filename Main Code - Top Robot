// INITIALIZE SERVO
void initialize_servos()
{
    enable_servos();
    int pos = get_servo_position(0);

    while(pos > 900)
    {
        pos -= 1;
        set_servo_position(0, pos);
        msleep(10);
    }
    msleep(500);
}
// UNIVERSAL SERVO
void move_servo_slow(int port, int target)
{
    int pos = get_servo_position(port);

    if(pos < target)
    {
        while(pos < target)
        {
            pos += SERVO_STEP;
            set_servo_position(port, pos);
            msleep(SERVO_DELAY);
        }
    }
    else
    {
        while(pos > target)
        {
            pos -= SERVO_STEP;
            set_servo_position(port, pos);
            msleep(SERVO_DELAY);
        }
    }

    set_servo_position(port, target);
    msleep(200);
}
// LOWER ARM
void lower_arm(int position)
{
    move_servo_slow(ARM_SERVO, position);
}
// RAISE ARM
void raise_arm(int position)
{
    move_servo_slow(ARM_SERVO, position);
}
// DRIVE STRAIGHT WITH ENCODERS
void driveStraight(double inches, double direction)
{
    double target = inches * TICKS_PER_INCH;

    cmpc(LEFT_MOTOR);
    cmpc(RIGHT_MOTOR);

    while(abs(get_motor_position_counter(LEFT_MOTOR)) < target ||
          abs(get_motor_position_counter(RIGHT_MOTOR)) < target)
    {
        mav(LEFT_MOTOR, direction * BASE_SPEED);
        mav(RIGHT_MOTOR, direction * BASE_SPEED);

        msleep(10);
    }

    freeze(LEFT_MOTOR);
    freeze(RIGHT_MOTOR);
}


// TURN WITH ENCODERS
void turnDegrees(double degrees)
{
    double direction = (degrees >= 0) ? 1 : -1;
    double target = abs(degrees) * TICKS_PER_DEGREE;

    cmpc(LEFT_MOTOR);
    cmpc(RIGHT_MOTOR);

    while(abs(get_motor_position_counter(LEFT_MOTOR)) < target)
    {
        mav(LEFT_MOTOR, direction * BASE_SPEED);
        mav(RIGHT_MOTOR, -direction * BASE_SPEED);

        msleep(10);
    }

    freeze(LEFT_MOTOR);
    freeze(RIGHT_MOTOR);
}


// SQUARE UP ON LINE
void square_up_on_line()
{
    while(analog(LEFT_SENSOR) < LINE || analog(RIGHT_SENSOR) < LINE)
    {
        if(analog(LEFT_SENSOR) < LINE && analog(RIGHT_SENSOR) > LINE)
        {
            mav(RIGHT_MOTOR,-500);
            mav(LEFT_MOTOR,800);
            
        }

        else if(analog(LEFT_SENSOR) > LINE && analog(RIGHT_SENSOR) < LINE)
        {
            mav(RIGHT_MOTOR,800);
            mav(LEFT_MOTOR,-500);
            
        }

    	else{
            mav(RIGHT_MOTOR,700);
            mav(LEFT_MOTOR,700);
            
        }

       
    }

    freeze(LEFT_MOTOR);
    freeze(RIGHT_MOTOR);
}

// SQUARE UP ON LINE BACKWARDS
void square_up_on_line_backwards()
{
    // Continue looping until BOTH sensors see the line (value > LINE)
    while(analog(LEFT_SENSOR) < LINE || analog(RIGHT_SENSOR) < LINE)
    {
        // Right sensor hit the line first, left is still on white
        if(analog(LEFT_SENSOR) < LINE && analog(RIGHT_SENSOR) > LINE)
        {
            mav(RIGHT_MOTOR, 200);   // Right side pivots forward
            mav(LEFT_MOTOR, -400);   // Left side keeps backing up to catch the line
        }
        // Left sensor hit the line first, right is still on white
        else if(analog(LEFT_SENSOR) > LINE && analog(RIGHT_SENSOR) < LINE)
        {
            mav(RIGHT_MOTOR, -400);  // Right side keeps backing up to catch the line
            mav(LEFT_MOTOR, 200);    // Left side pivots forward
        }
        // Neither sensor sees the line, drive straight backwards
        else 
        {
            mav(RIGHT_MOTOR, -1000);
            mav(LEFT_MOTOR, -1000);
        }
    }

    // Stop both motors once the line is squared up
    freeze(LEFT_MOTOR);
    freeze(RIGHT_MOTOR);
}


// LINE FOLLOW USING ENCODERS (DISTANCE)
void line_follow_inches(int inches)
{
    int target = inches * TICKS_PER_INCH;

    cmpc(LEFT_MOTOR);
    cmpc(RIGHT_MOTOR);

    while(abs(get_motor_position_counter(LEFT_MOTOR)) < target)
    {
        if(analog(LEFT_SENSOR) < LINE && analog(RIGHT_SENSOR) > LINE)
        {
            mav(RIGHT_MOTOR,-700);
            mav(LEFT_MOTOR,700);
            
        }

        else if(analog(LEFT_SENSOR) > LINE && analog(RIGHT_SENSOR) < LINE)
        {
            mav(RIGHT_MOTOR,700);
            mav(LEFT_MOTOR,-700);
            
        }

    	else{
            mav(RIGHT_MOTOR,0.95 * BASE_SPEED);
            mav(LEFT_MOTOR,0.95 * BASE_SPEED);
            
        }
        msleep(10);
    }

    freeze(LEFT_MOTOR);
    freeze(RIGHT_MOTOR);
}

// MOVE ARM BY DEGREES WITH ENCODERS (positive = raise, negative = lower)
void move_arm(double degrees)
{
    double direction = (degrees >= 0) ? 1 : -1;
    double target = abs(degrees) * TICKS_PER_DEGREE_ARM;

    cmpc(POM_ARM);

    while(abs(get_motor_position_counter(POM_ARM)) < target)
    {
        mav(POM_ARM, direction * 1500);
        msleep(10);
    }

    freeze(POM_ARM);
}
