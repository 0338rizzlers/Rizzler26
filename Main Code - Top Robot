// SQUARE UP WHILE ARM
void square_up_while_arm(double arm_degrees)
{
    double arm_target = abs(arm_degrees) * TICKS_PER_DEGREE_ARM;
    double arm_dir = (arm_degrees >= 0) ? 1 : -1;
    cmpc(POM_ARM);

    while(analog(LEFT_SENSOR) < LINE || analog(RIGHT_SENSOR) < LINE ||
          abs(get_motor_position_counter(POM_ARM)) < arm_target)
    {
        // Square up logic
        if(analog(LEFT_SENSOR) < LINE && analog(RIGHT_SENSOR) > LINE)
        {
            mav(RIGHT_MOTOR, -500);
            mav(LEFT_MOTOR, 800);
        }
        else if(analog(LEFT_SENSOR) > LINE && analog(RIGHT_SENSOR) < LINE)
        {
            mav(RIGHT_MOTOR, 800);
            mav(LEFT_MOTOR, -500);
        }
        else
        {
            mav(RIGHT_MOTOR, 700);
            mav(LEFT_MOTOR, 700);
        }

        // Arm logic runs every loop iteration simultaneously
        if(abs(get_motor_position_counter(POM_ARM)) < arm_target)
            mav(POM_ARM, arm_dir * 1500);
        else
            freeze(POM_ARM);

        msleep(10);
    }

    freeze(LEFT_MOTOR);
    freeze(RIGHT_MOTOR);
    freeze(POM_ARM);
}

// SQUARE UP BACKWARDS WHILE ARM
void square_up_back_while_arm(double arm_degrees)
{
    double arm_target = abs(arm_degrees) * TICKS_PER_DEGREE_ARM;
    double arm_dir = (arm_degrees >= 0) ? 1 : -1;
    cmpc(POM_ARM);

    while(analog(LEFT_SENSOR) < LINE || analog(RIGHT_SENSOR) < LINE ||
          abs(get_motor_position_counter(POM_ARM)) < arm_target)
    {
        if(analog(LEFT_SENSOR) < LINE && analog(RIGHT_SENSOR) > LINE)
        {
            mav(RIGHT_MOTOR, 200);
            mav(LEFT_MOTOR, -400);
        }
        else if(analog(LEFT_SENSOR) > LINE && analog(RIGHT_SENSOR) < LINE)
        {
            mav(RIGHT_MOTOR, -400);
            mav(LEFT_MOTOR, 200);
        }
        else
        {
            mav(RIGHT_MOTOR, -1000);
            mav(LEFT_MOTOR, -1000);
        }

        if(abs(get_motor_position_counter(POM_ARM)) < arm_target)
            mav(POM_ARM, arm_dir * 1500);
        else
            freeze(POM_ARM);

        msleep(10);
    }

    freeze(LEFT_MOTOR);
    freeze(RIGHT_MOTOR);
    freeze(POM_ARM);
}

