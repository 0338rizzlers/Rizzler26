#include <kipr/wombat.h>
#include <stdlib.h>

// MOTORS
#define left 1
#define right 3
#define vmax 1500
// SERVO SETTINGS
#define arm 0 
#define lclaw 0
#define rclaw 2
#define rear 1

#define arm_down_val 1536
#define arm_up_val 0
#define arm_above_ground_val 1080

#define lclaw_open_val -270
#define lclaw_close_val 270

#define rclaw_open_val -270
#define rclaw_close_val 270

#define rear_open 1230
#define rear_close 650

#define SERVO_STEP 10
#define fast 5
#define std 15
#define slow 20

#define claw_fast 1500
#define claw_std 400
#define claw_slow 300
// SENSORS
#define lc 3
#define rc 2

// CONSTANTS
#define BASE_SPEED 800
#define LINE 2200

#define TICKS_PER_INCH 285
#define TICKS_PER_DEGREE 12.1


// UNIVERSAL SERVO
void serbo(int port, int target, int SERVO_DELAY)
{
    int pos = get_servo_position(port);

    if(pos < target)
    {
        while(pos < target)
        {
            pos += SERVO_STEP;
            set_servo_position(port, pos);
            msleep(SERVO_DELAY);
        }
    }
    else
    {
        while(pos > target)
        {
            pos -= SERVO_STEP;
            set_servo_position(port, pos);
            msleep(SERVO_DELAY);
        }
    }

    set_servo_position(port, target);
    msleep(200);
}

// DRIVE STRAIGHT WITH ENCODERS
void driveStraight(double inches, double direction){
    double target = inches * TICKS_PER_INCH;

    cmpc(left);
    cmpc(right);

    while(abs(get_motor_position_counter(left)) < target ||
          abs(gmpc(right)) < target)
    {
        mav(left, direction * BASE_SPEED);
        mav(right, direction * BASE_SPEED);

        msleep(10);
    }

    freeze(left);
    freeze(right);
}

void driveTime(double speed, double duration){
    mav(left, speed);
    mav(right, speed);
    msleep(duration);
    freeze(left);
    freeze(right);
}

// TURN WITH ENCODERS
void turnDegrees(double degrees){
    double direction = (degrees >= 0) ? 1 : -1;
    double target = abs(degrees) * TICKS_PER_DEGREE;

    cmpc(left);
    cmpc(right);

    while(abs(gmpc(left)) < target)
    {
        mav(left, direction * BASE_SPEED);
        mav(right, -direction * BASE_SPEED);

        msleep(10);
    }

    freeze(left);
    freeze(right);
}

void closeClaw(int speed){
		cmpc(lclaw);
    cmpc(rclaw);
    while(gmpc(lclaw) < lclaw_close_val && gmpc(rclaw) < rclaw_close_val  ){
        mav(lclaw, speed);
        mav(rclaw, speed);
        msleep(1);
    }
    freeze(lclaw);
    freeze(rclaw);
	}

void openClaw(int speed){
	cmpc(lclaw);
    cmpc(rclaw);
    while(gmpc(lclaw) > lclaw_open_val && gmpc(rclaw) > rclaw_open_val  ){
        mav(lclaw, -(speed));
        mav(rclaw, -(speed));
        msleep(1);
    }
    freeze(lclaw);
    freeze(rclaw);
	}
	

void openRear(int speed){
    serbo(rear, rear_open, speed);
}

void closeRear(int speed){
    serbo(rear, rear_close, speed);

}
void armUp(int speed){
    serbo(arm, arm_up_val, speed);
}

void armDown(int speed){
    serbo(arm, arm_down_val, speed);
}

void armAboveGround(int speed){
    serbo(arm, arm_above_ground_val, speed);
}

// SQUARE UP ON LINE
void square_up_on_line()
{
    while(analog(lc) < LINE || analog(rc) < LINE)
    {
        if(analog(lc) < LINE && analog(rc) > LINE)
        {
            mav(right,-500);
            mav(left,800);
            
        }

        else if(analog(lc) > LINE && analog(rc) < LINE)
        {
            mav(right,800);
            mav(left,-500);
            
        }

    	else{
            mav(right,700);
            mav(left,700);
            
        }

       
    }

    freeze(left);
    freeze(right);
}
// SQUARE UP ON LINE BACKWARDS
void square_up_on_line_backwards(){
    // Continue looping until BOTH sensors see the line (value > LINE)
    while(analog(lc) < LINE || analog(rc) < LINE)
    {
        // Right sensor hit the line first, left is still on white
        if(analog(lc) < LINE && analog(rc) > LINE)
        {
            mav(right, 200);   // Right side pivots forward
            mav(left, -400);   // Left side keeps backing up to catch the line
        }
        // Left sensor hit the line first, right is still on white
        else if(analog(lc) > LINE && analog(rc) < LINE)
        {
            mav(right, -400);  // Right side keeps backing up to catch the line
            mav(left, 200);    // Left side pivots forward
        }
        // Neither sensor sees the line, drive straight backwards
        else 
        {
            mav(right, -1000);
            mav(left, -1000);
        }
    }

    // Stop both motors once the line is squared up
    freeze(left);
    freeze(right);
}


// LINE FOLLOW USING ENCODERS (DISTANCE)
void line_follow_inches(int inches)
{
    int target = inches * TICKS_PER_INCH;

    cmpc(left);
    cmpc(right);

    while(abs(gmpc(left)) < target)
    {
        if(analog(lc) < LINE && analog(rc) > LINE)
        {
            mav(right,-700);
            mav(left,700);
            
        }

        else if(analog(lc) > LINE && analog(rc) < LINE)
        {
            mav(right,700);
            mav(left,-700);
            
        }

    	else{
            mav(right,0.95 * BASE_SPEED);
            mav(left,0.95 * BASE_SPEED);
            
        }
        msleep(10);
    }

    freeze(left);
    freeze(right);
}
void sqol(){
    while(analog(lc) < LINE || analog(rc) < LINE)
    {
        if(analog(lc) < LINE && analog(rc) > LINE)
        {
            mav(left,800);
            mav(right,-600);
            printf("Left sensor value: %d  Right sensor value: %d\n", lc, rc);

        }

        else if(analog(lc) > LINE && analog(rc) < LINE)
        {
            mav(left,-600);
            mav(right,800);

        }

        else{
            mav(right,800);
            mav(left,800);

        }
		 

    }

    freeze(left);
    freeze(right);
}
